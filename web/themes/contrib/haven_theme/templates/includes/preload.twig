{#
/**
 * @file
 * Preload the commonly used fonts for the headings and the body copy.
 *
 * Available variables:
 * - haven_theme_path: Returns the path to the HavenTheme theme.
 */
#}

<link rel="preload" href="{{ haven_theme_path }}/fonts/Gelasio/Gelasio-var.ttf" as="font" type="font/ttf" crossorigin />
<link rel="preload" href="{{ haven_theme_path }}/fonts/Geist/Geist-var.ttf" as="font" type="font/ttf" crossorigin />
