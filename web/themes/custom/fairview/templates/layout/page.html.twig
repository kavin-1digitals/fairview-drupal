        cta_url:   '/care',
      },
      {
        modifier:  'secondary',
        heading:   'Got the Flu? Try an E-Visit',
        body:      'E-visits are a quick and convenient care option for flu-like symptoms.',
        cta_label: 'Start an e-visit',
        cta_url:   '/care/evisits',
      },
    ]
  } only %}
{% endif %}

{# ── Feature cards — front page only ────────────────────────────────── #}
{% if is_front %}
  {% include '@fairview/components/feature-cards/feature-cards.twig' with {
    cards: [
      {
        image_url: base_path ~ directory ~ '/images/providers.svg',
        image_alt: 'Providers illustration',
