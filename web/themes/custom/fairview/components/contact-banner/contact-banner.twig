{#
/**
 * @file
 * Shared contact / scheduling strip (dark bar, phone icon).
 *
 * Expects preprocess (fairview_preprocess_page or module preprocess) to set:
 * - contact_banner_title (plain text)
 * - contact_banner_phones: list of { tel: '+1…', label: 'display' }
 */
#}
{% if contact_banner_phones|default([])|length %}
  <footer class="contact-banner" role="contentinfo">
    <div class="contact-banner__inner">
      <span class="contact-banner__icon-wrap" aria-hidden="true">
        <svg class="contact-banner__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="currentColor"/>
        </svg>
      </span>
      <div class="contact-banner__body">
        {% if contact_banner_title|default('')|trim != '' %}
          <span class="contact-banner__title">{{ contact_banner_title }}</span>
        {% endif %}
        <span class="contact-banner__phones">
          {% for phone in contact_banner_phones %}
            <a class="contact-banner__phone" href="{{ ('tel:' ~ phone.tel)|e('html_attr') }}">{{ phone.label }}</a>
            {% if not loop.last %}
              <span class="contact-banner__sep" aria-hidden="true">|</span>
            {% endif %}
          {% endfor %}
        </span>
      </div>
    </div>
  </footer>
{% endif %}
