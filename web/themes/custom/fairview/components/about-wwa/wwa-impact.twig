{#
/**
 * @file
 * Our Impact — three columns with stat + underline.
 */
#}
<section class="wwa-band" aria-labelledby="wwa-impact-title">
  <div class="wwa-band__inner">
    <h2 id="wwa-impact-title" class="wwa-band__title">{{ 'Our Impact'|t }}</h2>
    <div class="wwa-cols wwa-cols--3 wwa-cols--impact">
      <div class="wwa-col wwa-col--stat">
        <h3 class="wwa-col__stat">$394 million</h3>
        <p class="wwa-col__desc">{{ 'In support of access to care and services'|t }}</p>
      </div>
      <div class="wwa-col wwa-col--stat">
        <h3 class="wwa-col__stat">$214 million</h3>
        <p class="wwa-col__desc">{{ 'For education and workforce development'|t }}</p>
      </div>
      <div class="wwa-col wwa-col--stat">
        <h3 class="wwa-col__stat">$11 million</h3>
        <p class="wwa-col__desc">{{ 'For hospital-based research and community programs and services'|t }}</p>
      </div>
    </div>
  </div>
</section>
