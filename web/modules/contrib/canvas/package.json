{
  "name": "@drupal-canvas/root",
  "version": "0.0.0",
  "description": "The Drupal Canvas module will 1) enable site builders without Drupal experience to easily theme and build their entire website using only their browser, without the need to write code beyond basic HTML, CSS, and templating markup (e.g., Twig) AND 2) it will enable content creators to and compose content on any part of the page without relying on developers.",
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "workspaces": [
    "packages/*",
    "ui",
    "docs/user",
    "tests/modules/canvas_test_extension"
  ],
  "scripts": {
    "test:playwright": "playwright install && playwright test",
    "lint:eslint": "eslint",
    "lint:openapi": "redocly lint openapi.yml",
    "lint:prettier": "prettier tests/src/Playwright playwright.config.ts packages ui eslint.config.mjs --check",
    "lint:stylelint": "stylelint stylelint \"**/*.css\"",
    "lint:tsc": "npm run type-check --workspaces",
    "lint:cspell": "cspell . --no-progress",
    "lint:yaml": "yamllint '**/*.(yaml|yml)' --ignore='.gitlab/**' --ignore='.gitlab-ci.yml' --ignore='node_modules/**'",
    "fix": "npm run lint:prettier -- --write && npm run lint:eslint -- --fix && npm run lint:stylelint -- --fix",
    "test": "npx concurrently --group npm:test:*",
    "lint": "npx concurrently --group npm:lint:*"
  },
  "repository": {
    "type": "git",
    "url": "git@git.drupal.org:project/canvas.git"
  },
  "author": "",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@drupal/playwright": "^1.1.1",
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@playwright/test": "^1.59.1",
    "@redocly/cli": "^2.25.3",
    "@types/node": "^22.14.0",
    "@vitest/eslint-plugin": "^1.6.3",
    "cspell": "^9.2.0",
    "dotenv-defaults": "^5.0.2",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-junit": "^9.0.1",
    "eslint-plugin-chai-friendly": "^1.1.0",
    "eslint-plugin-cypress": "^5.2.0",
    "eslint-plugin-mocha": "^11.2.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "concurrently": "^9.2.1",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "stylelint": "^17.6.0",
    "stylelint-checkstyle-formatter": "^0.1.2",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "typescript-eslint": "^8.50.1",
    "yaml-lint": "^1.7.0"
  },
  "overrides": {
    "glob": "^13.0.1",
    "yaml": "^2.8.3",
    "@drupal-canvas/ui": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0"
    }
  }
}
