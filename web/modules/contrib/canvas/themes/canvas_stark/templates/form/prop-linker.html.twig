{#
/**
 * @file
 * Default theme implementation for a prop linker.
 *
 * Available variables:
 * - linked: Boolean indicating whether the prop is currently linked.
 * - prop_name: The name of the prop the linker is associated with.
 * - suggestions: An array of suggested fields to link to.
 */
#}
<drupal-canvas-prop-linker
  linked="{{ linked }}"
  prop-name="{{ prop_name }}"
  suggestions="{{ suggestions }}"
>
</drupal-canvas-prop-linker>
