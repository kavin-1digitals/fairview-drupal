{#
/**
 * @file
 * Canvas Stark override for an 'input' #type form element.
 *
 * Available variables:
 * - attributes: A list of HTML attributes for the input element.
 * - children: Optional additional rendered elements.
 *
 * @see template_preprocess_input()
 *
 * @ingroup themeable
 */
#}
<drupal-canvas-input--multivalue-form
  attributes="{{ attributes }}"
  type="{{ type }}"
></drupal-canvas-input--multivalue-form>{{ children }}
