{#
/**
 * @file
 * Canvas Stark override for a 'form' element.
 *
 * Available variables
 * - attributes: A list of HTML attributes for the wrapper element.
 * - children: The child elements of the form.
 *
 * @see template_preprocess_form()
 *
 * @ingroup themeable
 */
#}
<drupal-canvas-form
    attributes="{{ attributes }}"
>
  {{ children }}
</drupal-canvas-form>

