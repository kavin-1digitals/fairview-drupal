{#
/**
 * @file
 * Default theme implementation for a linked field box.
 *
 * Available variables:
 * - title: The title the box displays.
 * - prop_name: The name of the prop the box is associated with.
 */
#}
<drupal-canvas-linked-field-box
    title="{{ title }}"
    prop-name="{{ prop_name }}"
>
</drupal-canvas-linked-field-box>
