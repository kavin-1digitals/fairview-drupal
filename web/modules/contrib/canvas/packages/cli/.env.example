# Drupal Canvas CLI example configuration
#
# Copy this file to `.env` in your project directory, or create a `.canvasrc` file in
# your home directory for global settings.

CANVAS_SITE_URL=https://canvas.ddev.site
CANVAS_CLIENT_ID=cli
CANVAS_CLIENT_SECRET=secret

# CANVAS_SCOPE="canvas:js_component canvas:asset_library canvas:brand_kit"

# Alternative to client credentials: provide a pre-issued Bearer token directly.
# When set, CANVAS_CLIENT_ID, CANVAS_CLIENT_SECRET, and CANVAS_SCOPE are ignored.
# CANVAS_ACCESS_TOKEN=your-access-token
