{% if primary_image and primary_image.src %}<img class="primary" src="{{ primary_image.src }}" alt="{{ primary_image.alt }}" />{% endif %}
{% if secondary_image and secondary_image.src %}<img class="secondary" src="{{ secondary_image.src }}" alt="{{ secondary_image.alt }}" />{% endif %}
{% if required_image and required_image.src %}<img class="required" src="{{ required_image.src }}" alt="{{ required_image.alt }}" />{% endif %}
