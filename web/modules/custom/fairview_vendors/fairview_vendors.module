<?php

/**
 * @file
 * Fairview Vendors page at /fairview-vendors.
 */

/**
 * Implements hook_preprocess_page().
 */
function fairview_vendors_preprocess_page(array &$variables): void {
  $current_path = \Drupal::service('path.current')->getPath();
  $alias = \Drupal::service('path_alias.manager')->getAliasByPath($current_path);
  if ($alias !== '/fairview-vendors') {
    return;
  }

  $variables['#attached']['library'][] = 'fairview/fairview-vendors';
  $variables['title'] = '';
}
