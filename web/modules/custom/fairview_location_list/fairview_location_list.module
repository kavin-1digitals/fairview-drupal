<?php

/**
 * @file
 * Location list page variables for /locations/list.
 */

/**
 * Implements hook_preprocess_page().
 */
function fairview_location_list_preprocess_page(array &$variables): void {
  $current_path = \Drupal::service('path.current')->getPath();
  $alias = \Drupal::service('path_alias.manager')->getAliasByPath($current_path);
  if ($alias !== '/locations/list') {
    return;
  }

  $variables['#attached']['library'][] = 'fairview/location-list';
  $variables['title'] = '';

  $variables['ll_popular_searches'] = [
    'Labs',
    'Urgent Care',
    'Family Medicine',
    'Diabetes',
    'Ear Nose and Throat',
    'OBGYN',
    'Hospital',
    'Mental Health',
  ];

  $variables['ll_filter_location_types'] = [
    ['id' => 'lt-lab', 'label' => 'Lab (56)'],
    ['id' => 'lt-imaging', 'label' => 'Imaging (36)'],
    ['id' => 'lt-clinic', 'label' => 'Clinic (35)'],
    ['id' => 'lt-primary', 'label' => 'Primary care (20)'],
    ['id' => 'lt-hospital', 'label' => 'Hospital (9)'],
    ['id' => 'lt-specialty', 'label' => 'Specialty clinic (8)'],
    ['id' => 'lt-walkin', 'label' => 'Walk-In Clinic (1)'],
  ];

  $variables['ll_filter_departments'] = [
    ['id' => 'dp-dh', 'label' => 'Digestive Health (7)'],
    ['id' => 'dp-gi', 'label' => 'Gastrointestinal & Liver (5)'],
    ['id' => 'dp-ent', 'label' => 'Ear, Nose & Throat (4)'],
    ['id' => 'dp-eye', 'label' => 'Eye Care (3)'],
    ['id' => 'dp-gender', 'label' => 'Gender Care (2)'],
    ['id' => 'dp-surg', 'label' => 'General Surgery (2)'],
    ['id' => 'dp-mh', 'label' => 'Mental Health & Addiction Care (2)'],
    ['id' => 'dp-ortho', 'label' => 'Orthopedic Care (2)'],
    ['id' => 'dp-wh', 'label' => "Women's Health (2)"],
  ];

  $variables['ll_filter_amenities'] = [
    ['id' => 'am-pf', 'label' => 'Parking- Free (3)'],
    ['id' => 'am-ph', 'label' => 'Pharmacy - InstyMeds (2)'],
    ['id' => 'am-dv', 'label' => 'Dining - Vending (2)'],
    ['id' => 'am-atm', 'label' => 'ATM (2)'],
    ['id' => 'am-sec', 'label' => 'Security Escort (2)'],
    ['id' => 'am-din', 'label' => 'Dining (2)'],
    ['id' => 'am-mob', 'label' => 'Mobility Assistance (2)'],
    ['id' => 'am-cof', 'label' => 'Dining - Coffee Shop (1)'],
    ['id' => 'am-cha', 'label' => 'Chapel (1)'],
    ['id' => 'am-pfee', 'label' => 'Parking - For a Fee (1)'],
    ['id' => 'am-gift', 'label' => 'Gift Shop (1)'],
    ['id' => 'am-ph2', 'label' => 'Pharmacy (1)'],
    ['id' => 'am-valet', 'label' => 'Valet Parking (1)'],
  ];

  $variables['ll_filter_services'] = [
    ['id' => 'sv-phys', 'label' => 'Annual Physicals (7)'],
    ['id' => 'sv-cfl', 'label' => 'Child Family Life Services (3)'],
    ['id' => 'sv-conc', 'label' => 'Concussion Testing (2)'],
    ['id' => 'sv-nut', 'label' => 'Nutrition Therapy (2)'],
    ['id' => 'sv-pedn', 'label' => 'Pediatric Nutrition Services (2)'],
    ['id' => 'sv-prev', 'label' => 'Preventative Care (2)'],
    ['id' => 'sv-sh', 'label' => 'Sexual Health Medical Services (2)'],
    ['id' => 'sv-vax', 'label' => 'Vaccines (2)'],
    ['id' => 'sv-air', 'label' => 'Airway Clearance Therapies (2)'],
    ['id' => 'sv-gyn', 'label' => 'Annual Gynecological Exam (2)'],
    ['id' => 'sv-anti', 'label' => 'Anticoagulation Medication Monitoring (2)'],
    ['id' => 'sv-ath', 'label' => 'Athletic Training (2)'],
    ['id' => 'sv-bio', 'label' => 'Biopsy (2)'],
    ['id' => 'sv-cl', 'label' => 'Central Line Care (2)'],
    ['id' => 'sv-can', 'label' => 'Child Abuse and Neglect Services (2)'],
    ['id' => 'sv-dia', 'label' => 'Diabetes Education (2)'],
    ['id' => 'sv-eye', 'label' => 'Eye Exam (2)'],
    ['id' => 'sv-glass', 'label' => 'Glasses & Contact Lens Sales (2)'],
    ['id' => 'sv-lac', 'label' => 'Lactation Specialists (2)'],
    ['id' => 'sv-lym', 'label' => 'Lymphedema Therapy (2)'],
    ['id' => 'sv-mam', 'label' => 'Mammogram (2)'],
    ['id' => 'sv-pcou', 'label' => 'Pediatric Counseling (2)'],
    ['id' => 'sv-preg', 'label' => 'Pregnancy and Birth (2)'],
  ];

  $variables['ll_results_summary'] = 'Showing 1 - 12 of 56 Results';
  $variables['footer_schedule_title'] = 'Contact Us 24/7:';
  $variables['footer_schedule_phone'] = '1-855-FAIRVIEW';
  $variables['ll_locations'] = fairview_location_list_mock_locations();
}

