<?php

/**
 * @file
 * Install hooks for Fairview Get Care.
 */

/**
 * Implements hook_install().
 */
function fairview_get_care_install(): void {
  _fairview_get_care_ensure_page();
}

/**
 * Create /get-care page node and alias if missing.
 */
function fairview_get_care_update_9001(): void {
  _fairview_get_care_ensure_page();
}

/**
 * Publish the Get Care page node when the alias exists.
 */
function fairview_get_care_update_9002(): void {
  $alias_storage = \Drupal::entityTypeManager()->getStorage('path_alias');
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $aliases = $alias_storage->loadByProperties(['alias' => '/get-care']);
  foreach ($aliases as $alias) {
    $path = $alias->getPath();
    if (!preg_match('/^\/node\/(\d+)$/', $path, $m)) {
      continue;
    }
    $node = $node_storage->load((int) $m[1]);
    if (!$node || $node->bundle() !== 'page') {
      continue;
    }
    $node->setPublished(TRUE);
    if ($node->hasField('moderation_state')) {
      $node->set('moderation_state', 'published');
    }
    $node->save();
    return;
  }
}

/**
 * Remove conflicting redirects and normalize the /get-care alias.
 */
function fairview_get_care_update_9003(): void {
  _fairview_get_care_delete_get_care_redirects();

  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $alias_storage = \Drupal::entityTypeManager()->getStorage('path_alias');

  $nids = $node_storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'page')
    ->condition('title', 'Get Care')
    ->range(0, 1)
    ->execute();

  if (!$nids) {
    _fairview_get_care_ensure_page();
    return;
  }

  $nid = (int) reset($nids);
  $internal = '/node/' . $nid;

  $pids = $alias_storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('path', $internal)
    ->execute();

  if ($pids) {
    $alias_storage->delete($alias_storage->loadMultiple($pids));
  }

  $node = $node_storage->load($nid);
  if (!$node) {
    _fairview_get_care_ensure_page();
    return;
  }

  $replacement = \Drupal\path_alias\Entity\PathAlias::create([
    'path' => $internal,
    'alias' => '/get-care',
    'langcode' => $node->language()->getId(),
  ]);
  $replacement->save();
}

/**
 * Creates a basic page node and path alias /get-care.
 */
function _fairview_get_care_ensure_page(): void {
  $alias_storage = \Drupal::entityTypeManager()->getStorage('path_alias');
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');

  $aliases = $alias_storage->loadByProperties(['alias' => '/get-care']);
  foreach ($aliases as $alias) {
    $path = $alias->getPath();
    if (preg_match('/^\/node\/(\d+)$/', $path, $m)) {
      $node = $node_storage->load((int) $m[1]);
      if ($node && $node->bundle() === 'page') {
        _fairview_get_care_delete_get_care_redirects();
        return;
      }
    }
  }

  $node = \Drupal\node\Entity\Node::create([
    'type' => 'page',
    'title' => 'Get Care',
    'status' => 1,
  ]);
  $node->save();

  $new_alias = \Drupal\path_alias\Entity\PathAlias::create([
    'path' => '/node/' . $node->id(),
    'alias' => '/get-care',
    'langcode' => $node->language()->getId(),
  ]);
  $new_alias->save();

  _fairview_get_care_delete_get_care_redirects();
}

/**
 * Deletes redirect(s) whose source path is "get-care".
 */
function _fairview_get_care_delete_get_care_redirects(): void {
  $db = \Drupal::database();
  if (!$db->schema()->tableExists('redirect')) {
    return;
  }
  $db->delete('redirect')
    ->condition('redirect_source__path', 'get-care')
    ->execute();
}
