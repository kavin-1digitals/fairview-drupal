/**
 * @file
 * Provider search page data and configuration.
 */

/**
 * Implements hook_theme().
 */
function fairview_provider_search_theme(): array {
  return [
    'provider_search_page' => [
      'variables' => [
        'search_heading' => '',
        'search_hint' => '',
        'alert_message' => '',
        'results_summary' => '',
        'footer_schedule_title' => '',
        'footer_schedule_phone' => '',
        'contact_banner_title' => '',
        'contact_banner_phones' => [],
        'providers' => [],
      ],
    ],
  ];
}

/**
 * Generate initials from a provider name.
 */
function fairview_provider_search_initials(string $name): string {
  $before = trim(explode(',', $name, 2)[0]);
  $parts = $before === '' ? [] : preg_split('/\s+/', $before);
  if ($parts === FALSE || $parts === []) {
    return '?';
  }
  if (count($parts) === 1) {
    $token = $parts[0];
    return strtoupper(substr($token, 0, min(2, strlen($token))));
  }
  $first = substr($parts[0], 0, 1);
  $last = substr($parts[count($parts) - 1], 0, 1);
  return strtoupper($first . $last);
}

