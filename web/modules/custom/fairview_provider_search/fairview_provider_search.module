/**
 * Implements hook_preprocess_page().
 */
function fairview_provider_search_preprocess_page(array &$variables): void {
  $current_path = \Drupal::service('path.current')->getPath();
  $alias = \Drupal::service('path_alias.manager')->getAliasByPath($current_path);
  if ($alias !== '/search') {
    return;
  }

  $config = \Drupal::config('fairview_provider_search.settings');
  $message = $config->get('alert_message');
  if (!is_string($message) || trim($message) === '') {
    $emergency = $config->get('alert_emergency') ?? '';
    $financial = $config->get('alert_financial') ?? '';
    $message = trim($emergency . (strlen((string) $emergency) && strlen((string) $financial) ? "\n\n" : '') . $financial);
  }

  $variables['search_heading'] = $config->get('search_heading') ?: 'What can we help you with?';
  $variables['search_hint'] = $config->get('search_hint') ?: 'Enter a Condition, Specility or Provider Name';
  $variables['alert_message'] = str_replace(["\r\n", "\r"], "\n", (string) $message);
  $variables['results_summary'] = $config->get('results_summary') ?: '3565 providers found';
  $variables['footer_schedule_title'] = $config->get('footer_schedule_title') ?: 'To Schedule an Appointment 24/7';
  $variables['footer_schedule_phone'] = $config->get('footer_schedule_phone') ?: '1-855-FAIRVIEW';
  $variables['providers'] = fairview_provider_search_mock_providers();
  $variables['#attached']['library'][] = 'fairview/provider-search';
  $variables['title'] = '';
}

/**
 * Implements hook_preprocess_HOOK() for provider_search_page.
 */
function fairview_provider_search_preprocess_provider_search_page(array &$variables): void {
  $config = \Drupal::config('fairview_provider_search.settings');
  $variables['footer_schedule_title'] = $config->get('footer_schedule_title') ?: 'To Schedule an Appointment 24/7';
  $variables['footer_schedule_phone'] = $config->get('footer_schedule_phone') ?: '1-855-FAIRVIEW';
  $label = (string) $variables['footer_schedule_phone'];
  $variables['contact_banner_title'] = (string) $variables['footer_schedule_title'];
  $variables['contact_banner_phones'] = [
    [
      'tel' => _fairview_provider_search_tel_from_display($label),
      'label' => $label,
    ],
  ];
  $variables['#attached']['library'][] = 'fairview/contact-banner';
}

/**
 * Builds a tel: URI from a display phone string (NANP-style).
 */
function _fairview_provider_search_tel_from_display(string $display): string {
  $digits = preg_replace('/\D+/', '', $display);
  if ($digits === '') {
    return '';
  }
  if (strlen($digits) === 11 && str_starts_with($digits, '1')) {
    return '+' . $digits;
  }
  if (strlen($digits) === 10) {
    return '+1' . $digits;
  }
  return '+' . $digits;
}
